<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.hailang.dao.RuleDao">

    <resultMap id="BaseResultMap" type="com.hailang.entity.Rule">
        <id column="id" property="id"/>
        <result column="uuid" property="uuid"/>
        <result column="name" property="name"/>
        <result column="flexibility" property="flexibility"/>
        <result column="start_time" property="startTime"/>
        <result column="end_time" property="endTime"/>
        <result column="middle_rest" property="middleRest"/>
        <result column="middle_start" property="middleStart"/>
        <result column="middle_end" property="middleEnd"/>
        <result column="vacation" property="vacation"/>
        <result column="comp" property="comp"/>
        <result column="accuracy" property="accuracy"/>
    </resultMap>

    <sql id="Base_Column_List">
        id, uuid, name, flexibility, start_time, end_time, middle_rest, middle_start, middle_end,
        vacation, comp, accuracy
    </sql>

</mapper>
